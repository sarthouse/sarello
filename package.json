{
  "name": "sarello-erp",
  "version": "0.1.0",
  "description": "Sistema ERP argentino con Django y Tailwind CSS",
  "scripts": {
    "dev": "postcss ./staticfiles/css/main.css -o ./staticfiles/css/output.css --watch",
    "build": "postcss ./staticfiles/css/main.css -o ./staticfiles/css/output.css --minify"
  },
  "dependencies": {
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "daisyui": "^4.12.24",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tailwindcss-animate": "^1.0.7"
  }
}
